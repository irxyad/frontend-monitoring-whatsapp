# Buat 2 file env terpisah (.env.development dan .env.production) sesuai environment
# Sesuaikan nilai tiap variabel dengan environment yang digunakan

# Base URL dari backend API
VITE_API_BASE_URL=http://localhost:3000

# Nama aplikasi yg ditampilkan di header dan sidebar
VITE_APP_NAME=Monitoring WhatsApp Automation

# Identifier environment aktif (development / production)
VITE_FLAVOR=development

# API key statis yang disediakan oleh backend
VITE_API_KEY=
